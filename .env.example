# Mac control bridge (shared secret — must match on all Macs running host-bridge/install.sh)
CLAUDE_CODE_OAUTH_TOKEN="claude-sdk-token"
ASSISTANT_NAME="Nano"
ENABLE_MAC_CONTROL=true
BRIDGE_SECRET=exampleofthebridgesecret
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN="some-bot-token"
MAX_MESSAGES_PER_PROMPT=10

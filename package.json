{
  "name": "nanoclaw",
  "version": "1.0.0",
  "description": "Claude Colleague: lightweight, secure, friendly.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky",

    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "LOG_LEVEL=debug node --import tsx/esm src/core/index.ts",
    "typecheck": "npx tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "setup": "npx tsx setup/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.119",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@playwright/mcp": "^0.0.70",
    "better-sqlite3": "^11.10.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
